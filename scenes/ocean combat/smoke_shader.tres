code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_toon, specular_toon;

uniform vec2 Texture_Scale = vec2(1.000000, 1.000000);
uniform sampler2D Disolver_Texture : source_color;



void fragment() {
// ColorConstant:7
	vec4 n_out7p0 = vec4(0.000000, 0.000000, 0.000000, 1.000000);


// Vector2Parameter:5
	vec2 n_out5p0 = Texture_Scale;


// UVFunc:4
	vec2 n_in4p2 = vec2(0.00000, 0.00000);
	vec2 n_out4p0 = n_in4p2 * n_out5p0 + UV;


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(Disolver_Texture, n_out4p0);
	float n_out2p1 = n_out2p0.r;


// Input:6
	vec4 n_out6p0 = COLOR;
	float n_out6p4 = n_out6p0.a;


// Output:0
	ALBEDO = vec3(n_out7p0.xyz);
	ALPHA = n_out2p1;
	EMISSION = vec3(n_out6p0.xyz);
	ALPHA_SCISSOR_THRESHOLD = n_out6p4;


}
"
